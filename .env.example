# Copy this file to .env and fill in real values locally.
# NEVER commit the actual .env file -- it's already in .gitignore.

GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: only needed if you swap the local JSON backlog store
# in mcp_server.py for a real integration.
JIRA_API_TOKEN=
JIRA_BASE_URL=
NOTION_API_KEY=

# Where the demo MCP server stores its local backlog file
BACKLOG_PATH=backlog.json
